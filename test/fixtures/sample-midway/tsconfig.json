{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "baseUrl": "./src",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": { "@/*": ["*"] },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "typeRoots": ["../../../node_modules/@types"]
  },
  "include": ["src/**/*"]
}
